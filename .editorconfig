# =============================================================================
# EditorConfig Configuration
# =============================================================================
# Maintains consistent coding styles across different editors and IDEs.
# Documentation: https://editorconfig.org
#
# Most modern editors support EditorConfig natively or via plugins:
# - VS Code: EditorConfig for VS Code extension
# - JetBrains: Built-in support
# - Vim: editorconfig-vim plugin
# - Neovim: Built-in support (0.9+) or editorconfig.nvim
#
# Note: For Rust files, rustfmt takes precedence over EditorConfig.
# This file ensures consistency for non-Rust files and editors without rustfmt.
# =============================================================================

root = true

# --- Default settings for all files ---
[*]
charset = utf-8
end_of_line = lf                    # Unix line endings (LF)
insert_final_newline = true         # Ensure files end with newline
trim_trailing_whitespace = true     # Remove trailing whitespace

# --- Rust files ---
# These should match .rustfmt.toml settings
[*.rs]
indent_style = space
indent_size = 2
max_line_length = 100

# --- TOML files (Cargo.toml, etc.) ---
[*.toml]
indent_style = space
indent_size = 2

# --- Markdown files ---
# Trailing whitespace can be significant in markdown (line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# --- YAML files ---
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# --- JSON files ---
[*.json]
indent_style = space
indent_size = 2

# --- Shell scripts ---
[*.sh]
indent_style = space
indent_size = 2

# --- Makefile ---
# Makefiles require tabs for recipes
[Makefile]
indent_style = tab

# --- Justfile ---
# Justfiles use spaces (not tabs like Makefile)
[justfile]
indent_style = space
indent_size = 4
